# Copie para .env e ajuste os valores em produção (VPS Papernow)
NODE_ENV=development
PORT=3000

# Segredo para assinar as sessões (JWT). Gere um valor longo e aleatório em produção:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-este-segredo-em-producao

# Ano do planner e início da semana 1 (primeira segunda-feira do ciclo do planner)
PLANNER_YEAR=2027
PLANNER_START=2027-01-04

# Limite de fotos por semana (PDF: até 3)
MAX_PHOTOS_PER_WEEK=3

# Segredo compartilhado para validar o webhook da Nuvemshop (defina em produção)
NUVEMSHOP_WEBHOOK_SECRET=

# Token para endpoints administrativos (seed manual de compradoras, etc.)
ADMIN_TOKEN=troque-este-token-admin
